{
  "name": "business-workflow-automation",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:up": "powershell -ExecutionPolicy Bypass -File scripts/dev-up.ps1",
    "dev:down": "powershell -ExecutionPolicy Bypass -File scripts/dev-down.ps1",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test:api:smoke": "cd backend && ..\\.venv\\Scripts\\python.exe test_api.py",
    "test:api:regression": "cd backend && ..\\.venv\\Scripts\\python.exe test_regression.py"
  },
  "dependencies": {
    "next": "16.2.2",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "eslint": "^9.28.0",
    "eslint-config-next": "16.2.2",
    "typescript": "^5.8.3"
  }
}